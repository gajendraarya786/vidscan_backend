# ── Allowed CORS origins ─────────────────────────────────────────────────────
# Use "*" to allow all origins (default), or a comma-separated list:
# ALLOWED_ORIGINS=https://app.example.com,https://preview.example.com
ALLOWED_ORIGINS=*

# ── Upload size limit (MB) ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
